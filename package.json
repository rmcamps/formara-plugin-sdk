{
  "name": "@formara/plugin-sdk",
  "version": "1.0.0",
  "description": "SDK para desarrollo de plugins de Formara",
  "main": "./backend/index.ts",
  "types": "./backend/index.d.ts",
  "bin": {
    "formara-sandbox": "./bin/formara-sandbox.js"
  },
  "exports": {
    "./backend": {
      "types": "./backend/index.d.ts",
      "import": "./backend/index.ts",
      "require": "./backend/index.js"
    },
    "./frontend": {
      "types": "./frontend/index.d.ts",
      "import": "./frontend/index.tsx"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "keywords": ["formara", "plugin", "sdk"],
  "author": "Formara",
  "license": "MIT",
  "peerDependencies": {
    "@prisma/client": "^5.0.0",
    "express": "^4.18.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "typescript": "^5.0.0"
  }
}

